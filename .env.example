# 로컬 개발: 설정하지 않으면 기본값 http://localhost:8080/api 사용
# 배포 빌드 시 예: VITE_API_BASE_URL=https://planit-ai.store/api
# VITE_API_BASE_URL=
# WebSocket(STOMP) 엔드포인트. 미설정 시 VITE_API_BASE_URL의 context-path를 이용해 /ws/chat으로 계산
# 예: ws://localhost:8080/api/ws/chat
# VITE_WS_BASE_URL=
# 로컬 테스트 시 일정 생성 시간 제한(14:00~02:00)을 우회하려면 true
# VITE_BYPASS_TRIP_CREATE_TIME_LIMIT=true
